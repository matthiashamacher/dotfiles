{{- $profile := index . "profile" | default "private" -}}
#!/bin/sh

# .osx {{ include "executable_dot_osx" | sha256sum }}
sudo ~/.osx


# Remove all apps from the Dock
defaults write com.apple.dock persistent-apps -array
killall "Dock" > /dev/null 2>&1 || true
sleep 2

{{ if eq $profile "work" -}}
# Work dock: daily tools → communication → dev tools
# 1Password
dockutil --add "/Applications/1Password.app/" --position 0 --label "1Password" --no-restart
# Google Chrome
dockutil --add "/Applications/Google Chrome.app/" --after "1Password" --label "Google Chrome" --no-restart
# Notion
dockutil --add "/Applications/Notion.app/" --after "Google Chrome" --label "Notion" --no-restart
# Slack
dockutil --add "/Applications/Slack.app/" --after "Notion" --label "Slack" --no-restart
# Microsoft Teams
dockutil --add "/Applications/Microsoft Teams.app/" --after "Slack" --label "Microsoft Teams" --no-restart
# Ghostty
dockutil --add "/Applications/Ghostty.app/" --after "Microsoft Teams" --label "Ghostty" --no-restart
# Tower
dockutil --add "/Applications/Tower.app/" --after "Ghostty" --label "Tower" --no-restart
# Cursor
dockutil --add "/Applications/Cursor.app/" --after "Tower" --label "Cursor" --no-restart

# Spacers
dockutil --add spacer --type small-spacer --after "Notion" --no-restart
dockutil --add spacer --type small-spacer --after "Microsoft Teams" --no-restart
{{ else -}}
# Private dock: daily tools → dev → media
# 1Password
dockutil --add "/Applications/1Password.app/" --position 0 --label "1Password" --no-restart
# Google Chrome
dockutil --add "/Applications/Google Chrome.app/" --after "1Password" --label "Google Chrome" --no-restart
# Notion
dockutil --add "/Applications/Notion.app/" --after "Google Chrome" --label "Notion" --no-restart
# Ghostty
dockutil --add "/Applications/Ghostty.app/" --after "Notion" --label "Ghostty" --no-restart
# Visual Studio Code
dockutil --add "/Applications/Visual Studio Code.app/" --after "Ghostty" --label "Visual Studio Code" --no-restart
# Tower
dockutil --add "/Applications/Tower.app/" --after "Visual Studio Code" --label "Tower" --no-restart
# Spotify
dockutil --add "/Applications/Spotify.app/" --after "Tower" --label "Spotify" --no-restart

# Spacer
dockutil --add spacer --type small-spacer --after "Notion" --no-restart
{{ end -}}

killall "Dock" > /dev/null 2>&1 || true
