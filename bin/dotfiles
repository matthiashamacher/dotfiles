function darwin_setup() {
    if ! [ -x "$(command -v brew)" ]; then
        _task "Installing Homebrew"
        _cmd '/bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"'
    fi
    if ! [ -x "$(command -v ansible)" ]; then
        _task "Installing Ansible"
        _cmd "brew install ansible"
        _task "Configuring ansible"
        _cmd "mkdir -p ~/.ansible"
        _cmd "echo '[all]
127.0.0.1  ansible_connection=local' > ~/.ansible/hosts"
        _cmd "mkdir -p ~/.ansible-vault"
        _cmd "touch $VAULT_SECRET"
        _task "Waiting for vault secret. Press enter to continue"
        _cmd "read -n 1 -s"
    fi
    if ! python3 -m pip show watchdog &> /dev/null; then
      _task "Installing watchdog"
      _cmd "python3 -m pip install watchdog --break-system-packages"
    fi
}

update_ansible_galaxy() {
  _task "Updating Ansible Galaxy"
  _cmd "ansible-galaxy install -r $DOTFILES_DIR/requirements.yml"
}

_task "Loading Setup for detected OS: $(uname -s)"
case $(uname -s) in
#   ubuntu)
#     ubuntu_setup
#     ;;
#   arch)
#     arch_setup
#     ;;
  Darwin)
    darwin_setup
    ;;
  *)
    _task "Unsupported OS"
    _cmd "echo 'Unsupported OS'"
    ;;
esac


# if ! [[ -f "$SSH_DIR/authorized_keys" ]]; then
#   _task "Generating SSH keys"
#   _cmd "mkdir -p $SSH_DIR"
#   _cmd "chmod 700 $SSH_DIR"
