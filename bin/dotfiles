#   _cmd "cat $SSH_DIR/id_rsa.pub >> $SSH_DIR/authorized_keys"
# fi

if [[ ! -d "$LOCAL_DIR/.git" ]]; then
  if ! [[ -d "$DOTFILES_DIR" ]]; then
    _task "Cloning repository"
    _cmd "git clone --quiet https://github.com/matthiashamacher/dotfiles.git $DOTFILES_DIR"
  else
    _task "Updating repository"
    _cmd "git -C $DOTFILES_DIR pull --quiet"
  fi
else
  DOTFILES_DIR=$LOCAL_DIR
fi

pushd "$DOTFILES_DIR" 2>&1 > /dev/null
update_ansible_galaxy $(uname -s)

_task "Running playbook"; _task_done
if [[ -f $VAULT_SECRET ]]; then
  ansible-playbook --vault-password-file $VAULT_SECRET "$DOTFILES_DIR/playbook.yml" --ask-become-pass "$@"
else
  ansible-playbook "$DOTFILES_DIR/playbook.yml" --ask-become-pass "$@"
fi

popd 2>&1 > /dev/null

if ! [[ -f "$IS_FIRST_RUN" ]]; then
  echo -e "${CHECK_MARK} ${GREEN}First run complete!${NC}"
  echo -e "${ARROW} ${CYAN}Please reboot your computer to complete the setup.${NC}"
  touch "$IS_FIRST_RUN"
fi
