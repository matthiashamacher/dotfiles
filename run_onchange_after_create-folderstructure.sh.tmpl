{{- $profile := index . "profile" | default "private" -}}
#!/bin/sh

# Folder structure is defined in .chezmoidata/folderstructure.yaml {{ include ".chezmoidata/folderstructure.yaml" | sha256sum }}

{{ if eq $profile "work" -}}
# Create folder structure for basecom
echo "Creating folder structure for basecom..."
{{ range .folderstructure.basecom -}}
mkdir -p "/Volumes/Projects/{{ . }}"
{{ end }}
{{ end -}}

# Create private folder structure
echo "Creating private folder structure..."
{{ range .folderstructure.private -}}
mkdir -p "/Volumes/Projects/{{ . }}"
{{ end -}}
